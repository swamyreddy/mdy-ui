{
  "name": "hpa-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port=4201",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev:ssr": "set NODE_OPTIONS=--openssl-legacy-provider && ng run hpaAngular:serve-ssr",
    "serve:ssr": "set NODE_OPTIONS=--openssl-legacy-provider && node dist/hpaAngular/server/main.js",
    "build:ssr": "set NODE_OPTIONS=--openssl-legacy-provider && ng build && ng run hpaAngular:server",
    "prerender": "ng run hpaAngular:prerender"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~12.2.17",
    "@angular/cdk": "^12.2.13",
    "@angular/common": "~12.2.17",
    "@angular/compiler": "~12.2.17",
    "@angular/core": "~12.2.17",
    "@angular/forms": "~12.2.17",
    "@angular/platform-browser": "~12.2.17",
    "@angular/platform-browser-dynamic": "~12.2.17",
    "@angular/platform-server": "~12.2.17",
    "@angular/router": "~12.2.17",
    "@fortawesome/angular-fontawesome": "^0.9.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@nguniversal/express-engine": "^12.0.2",
    "bootstrap": "^5.2.3",
    "bootstrap-icons": "^1.10.3",
    "express": "^4.15.2",
    "hammerjs": "^2.0.8",
    "rxjs": "~6.6.0",
    "tslib": "^2.1.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~12.2.17",
    "@angular/cli": "~12.2.17",
    "@angular/compiler-cli": "~12.2.17",
    "@nguniversal/builders": "^12.0.2",
    "@types/express": "^4.17.0",
    "@types/hammerjs": "^2.0.41",
    "@types/jasmine": "~3.6.0",
    "@types/node": "^12.11.1",
    "bootstrap-select": "^1.13.18",
    "jasmine-core": "~3.8.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "typescript": "~4.2.4"
  }
}
